# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Contact / enquiry email (SMTP — Namecheap Private Email) ---
# Namecheap Private Email SMTP. SMTP_USER/PASS are your mailbox login.
# The "from" address must be your own mailbox (providers won't relay others).
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=hello@phonicstophysics.com
SMTP_PASS=
CONTACT_NOTIFY_EMAIL=hello@phonicstophysics.com
CONTACT_FROM_EMAIL="Phonics to Physics <hello@phonicstophysics.com>"

# --- Spam protection (hCaptcha) ---
NEXT_PUBLIC_HCAPTCHA_SITEKEY=
HCAPTCHA_SECRET=

# --- Auth + Database (Supabase) — Phase 2+ ---
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # secret — server-only, bypasses RLS
# Project Settings → Database → Connection string (used for migrations/ORM)
DATABASE_URL=

# --- Payments (Stripe) — Phase 3 ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=                 # from the Stripe webhook endpoint
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# One Stripe Price id per tier per pack size (create as one-time GBP prices)
STRIPE_PRICE_PRIMARY_1=                # £30
STRIPE_PRICE_PRIMARY_10=              # £270
STRIPE_PRICE_SECONDARY_1=             # £35
STRIPE_PRICE_SECONDARY_10=            # £315
STRIPE_PRICE_ALEVEL_1=                # £40
STRIPE_PRICE_ALEVEL_10=              # £360

# --- Scheduling (Cal.com) — Phase 3 ---
CALCOM_API_KEY=
CALCOM_WEBHOOK_SECRET=                 # from the Cal.com webhook
# Booking URL for each tier's 55-min event type (public)
NEXT_PUBLIC_CALCOM_EVENT_PRIMARY=
NEXT_PUBLIC_CALCOM_EVENT_SECONDARY=
NEXT_PUBLIC_CALCOM_EVENT_ALEVEL=

# --- Token policy ---
TOKEN_EXPIRY_MONTHS=6
CANCEL_WINDOW_HOURS=24
# Protects the daily expiry cron. Set any long random string in Vercel;
# Vercel Cron automatically sends it as the Authorization bearer.
CRON_SECRET=
