# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Contact / enquiry email (SMTP — Namecheap Private Email) ---
# Namecheap Private Email SMTP. SMTP_USER/PASS are your mailbox login.
# The "from" address must be your own mailbox (providers won't relay others).
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=hello@phonicstophysics.com
SMTP_PASS=
CONTACT_NOTIFY_EMAIL=hello@phonicstophysics.com
CONTACT_FROM_EMAIL="Phonics to Physics <hello@phonicstophysics.com>"

# --- Spam protection (hCaptcha) ---
NEXT_PUBLIC_HCAPTCHA_SITEKEY=
HCAPTCHA_SECRET=

# --- Database (Supabase / Postgres) — Phase 2+ ---
DATABASE_URL=

# --- Auth (Clerk) — Phase 2+ ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Payments (Stripe) — Phase 3+ ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
