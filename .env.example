# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Contact / enquiry email (Resend) ---
# Sign up at https://resend.com, verify the phonicstophysics.com domain,
# then create an API key. Enquiry notifications + auto-replies use this.
RESEND_API_KEY=
CONTACT_NOTIFY_EMAIL=hello@phonicstophysics.com
CONTACT_FROM_EMAIL="Phonics to Physics <hello@phonicstophysics.com>"

# --- Spam protection (hCaptcha) ---
NEXT_PUBLIC_HCAPTCHA_SITEKEY=
HCAPTCHA_SECRET=

# --- Database (Supabase / Postgres) — Phase 2+ ---
DATABASE_URL=

# --- Auth (Clerk) — Phase 2+ ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Payments (Stripe) — Phase 3+ ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
